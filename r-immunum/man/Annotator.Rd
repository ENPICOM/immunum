\examples{
ann <- Annotator$new(c("H", "K", "L"), "imgt")
seq <- paste0(
  "QVQLVQSGAEVKRPGSSVTVSCKASGGSFSTYALSWVRQAPGRGLEWMGGVIPLLTITNYAPRFQ",
  "GRITITADRSTSTAYLELNSLRPEDTAVYYCAREGTTGKPIGAFAHWGQGTLVTVSS"
)
result <- ann$number(seq)
result$chain        # "H"
result$scheme       # "IMGT"
result$confidence   # numeric in [0, 1]
head(result$numbering)

seg <- ann$segment(seq)
seg$fr1
seg$cdr3
}
